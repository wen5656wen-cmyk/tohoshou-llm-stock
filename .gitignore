# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# runtime data (subscribers, logs)
/data/
/logs/

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# push logs
/logs

# prisma local db
prisma/dev.db

# reports (data files only — API routes at app/api/reports/ are NOT excluded)
/reports

# logs
*.log
