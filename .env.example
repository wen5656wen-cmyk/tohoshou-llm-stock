DATABASE_URL=

JQUANTS_EMAIL=
JQUANTS_PASSWORD=

OPENAI_API_KEY=

LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# 企业微信群机器人（旧，被 daily-picks 路由使用）
WECHAT_WORK_WEBHOOK_URL=

# 企业微信群机器人 Webhook（旧，仅 daily-picks 路由仍使用）
# 晨报/预警/收盘推送已迁移到长连接（WECOM_AIBOT_*），此项可留空
WECOM_WEBHOOK_URL=

# 企业微信智能机器人问答接口鉴权 Token（v11.3）
# 未配置时开发环境允许访问；生产环境强烈建议配置
CHAT_API_TOKEN=

# 企业微信智能机器人长连接（v11.4）
# PM2 进程：tohoshou-wecom-aibot（scripts/wecom-aibot-worker.ts）
WECOM_AIBOT_ID=           # 智能机器人 ID
WECOM_AIBOT_SECRET=       # 智能机器人 Secret
WECOM_AIBOT_CHAT_ID=      # 目标群聊 chatid（在群里 @机器人 后从 worker 日志获取）
WECOM_AIBOT_CHAT_TYPE=2   # 群聊=2（默认）
WECOM_AIBOT_INTERNAL_TOKEN=  # 本地 HTTP /send 鉴权 Token（可选，防止本机其他进程误调用）

# 企业微信智能机器人回调 URL（v11.5）
# 回调 URL：https://aitohoshou.com/api/wecom/callback
WECOM_BOT_ID=             # 智能机器人 BotID（用于日志记录）
WECOM_TOKEN=              # 企业微信后台配置的 Token
WECOM_AES_KEY=            # EncodingAESKey（43 字符，不含末尾 =）

# 企业微信客户联系一对一私信群发（v11.6）
# Secret 必须用「客户联系」Secret，不是自建应用 Secret
WECOM_CORP_ID=            # 企业ID（CorpID）
WECOM_CUSTOMER_SECRET=    # 客户联系 Secret（自动拉取客户列表，无需手填 external_userid）

NEXT_PUBLIC_APP_URL=
