generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Stock {
  id                 Int       @id @default(autoincrement())
  symbol             String    @unique
  name               String
  nameZh             String?
  nameEn             String?
  market             String    @default("TSE")
  price              Float     @default(0)
  change             Float?
  changeRate         Float?
  marketCap          Float? // 億円
  per                Float?
  pbr                Float?
  roe                Float?
  roa                Float?
  dividend           Float? // %
  sector             String?
  industry           String?
  scaleCategory      String? // LARGE | MID | SMALL
  description        String?
  website            String?
  employees          Int?
  aiScore            Int? // 0-100
  eps                Float?
  bps                Float?
  high52w            Float?
  low52w             Float?
  volume             Float?
  avgVolume          Float?
  beta               Float?
  lastSyncAt         DateTime?
  // V12.3 Rule 4 Phase 2: Hard Block fields (populated by external data sync; default = active)
  isDelisted         Boolean   @default(false) // true = delisted from exchange
  isSuspended        Boolean   @default(false) // true = trading suspended
  tradingStatus      String? // ACTIVE | SUSPENDED | HALTED
  listingStatus      String? // LISTED | DELISTED
  // P1-T1 AI Universe Filter: maintainable stock pool for AI scoring
  aiEnabled          Boolean   @default(true) // false = excluded from all AI scoring flows
  excludeReason      String? // reason code when aiEnabled=false (LOW_LIQUIDITY|LOW_GROWTH|POOR_DATA|ETF|ETN|REIT|PREFERRED|DELISTED|SUSPENDED|MANUAL|OTHER)
  // P1-T2 AI Universe Guard: automatic exclusion provenance
  aiExcludeSource    String? // MANUAL | AUTO | SYSTEM — who set the current state (null=clean enabled)
  aiExcludeRule      String? // matched rule code (also warning marker when aiEnabled=true & source=MANUAL)
  aiExcludeUpdatedAt DateTime? // last universe-state change (manual or auto)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  financials  Financial[]
  news        News[]
  portfolios  Portfolio[]
  disclosures Disclosure[]

  @@index([aiEnabled])
}

model Financial {
  id               Int       @id @default(autoincrement())
  stockId          Int
  stock            Stock     @relation(fields: [stockId], references: [id])
  fiscalYear       Int
  quarter          Int?
  revenue          Float?
  operatingProfit  Float?
  ordinaryProfit   Float?
  netProfit        Float?
  totalAssets      Float?
  equity           Float?
  eps              Float?
  bps              Float?
  roe              Float?
  roa              Float?
  equityRatio      Float?
  dividendPerShare Float?
  reportedAt       DateTime?
  source           String    @default("manual") // jquants | yahoo | manual
  createdAt        DateTime  @default(now())

  @@unique([stockId, fiscalYear, quarter])
  @@index([stockId])
}

model DailyPrice {
  id        Int      @id @default(autoincrement())
  symbol    String
  date      DateTime @db.Date
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  adjClose  Float?
  source    String   @default("yahoo") // yahoo | jquants
  createdAt DateTime @default(now())

  @@unique([symbol, date])
  @@index([symbol, date(sort: Desc)])
}

model Dividend {
  id          Int       @id @default(autoincrement())
  symbol      String
  year        Int
  quarter     Int?
  dividend    Float // 一株配当
  yieldRate   Float? // 配当利回り %
  payoutRatio Float? // 配当性向 %
  exDivDate   DateTime? @db.Date
  payDate     DateTime? @db.Date
  source      String    @default("yahoo")
  createdAt   DateTime  @default(now())

  @@unique([symbol, year, quarter])
  @@index([symbol])
}

model Disclosure {
  id          Int      @id @default(autoincrement())
  stockId     Int?
  stock       Stock?   @relation(fields: [stockId], references: [id])
  symbol      String
  title       String
  publishedAt DateTime
  category    String // EARNINGS | FORECAST_REVISION | BUYBACK | DIVIDEND | EQUITY | MATERIAL | OTHER
  summary     String?  @db.Text
  sentiment   String? // POSITIVE | NEGATIVE | NEUTRAL
  url         String   @unique
  importance  Int      @default(0)
  rawData     Json?
  createdAt   DateTime @default(now())

  @@index([symbol])
  @@index([publishedAt(sort: Desc)])
  @@index([category])
}

model News {
  id                      Int       @id @default(autoincrement())
  stockId                 Int?
  stock                   Stock?    @relation(fields: [stockId], references: [id])
  title                   String
  content                 String?   @db.Text
  summary                 String?   @db.Text
  source                  String
  url                     String    @unique
  publishedAt             DateTime
  sentiment               String?
  importance              Int       @default(0)
  category                String    @default("OTHER")
  relatedSymbolConfidence Int       @default(0)
  tradeEffectiveDate      DateTime? @db.Date // V12.0: first trading day on which this news can be used
  createdAt               DateTime  @default(now())

  @@index([stockId])
  @@index([publishedAt(sort: Desc)])
  @@index([relatedSymbolConfidence])
  @@index([category])
  @@index([tradeEffectiveDate])
}

model Portfolio {
  id        Int      @id @default(autoincrement())
  stockId   Int?
  stock     Stock?   @relation(fields: [stockId], references: [id])
  symbol    String
  name      String
  shares    Float
  avgPrice  Float
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([symbol])
}

model SyncLog {
  id         Int      @id @default(autoincrement())
  source     String // jquants | yahoo | tdnet
  status     String // SUCCESS | ERROR | PARTIAL
  message    String?
  itemCount  Int      @default(0)
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([source, createdAt(sort: Desc)])
}

// Pre-computed screener scores (materialized via scripts/compute-scores.ts)
model StockScore {
  symbol                   String    @id
  name                     String
  nameZh                   String?
  market                   String?
  sector                   String?
  industry                 String?
  scaleCategory            String?
  computedAt               DateTime
  priceCount               Int       @default(0)
  latestDate               String?
  latestClose              Float?
  return5d                 Float?
  return20d                Float?
  return60d                Float?
  rsi14                    Float?
  macd                     Float?
  macdSignal               Float?
  macdHist                 Float?
  maTrend                  String?
  macdSignalLabel          String?
  // V2 5-dimension scores (sum = totalScore 0-100)
  technicalScore           Int? // 0-30
  fundamentalScore         Int? // 0-25
  moneyFlowScore           Int? // 0-20 (proxy until InstitutionalFlow data available)
  newsSentimentScore       Int? // 0-15
  globalTrendScore         Int? // 0-10
  // Legacy (kept for DB compat, same as moneyFlowScore)
  riskScore                Int?
  totalScore               Int?
  recommendation           String?
  starsLabel               String?
  summaryReason            String?
  newsSummary              String?   @db.Text
  // V3.1: data source transparency (REAL | PARTIAL | FALLBACK)
  moneyFlowSource          String? // "jpx" | "jpx_file" | "v2_proxy" | "synthetic"
  globalTrendSource        String? // "yahoo" | "v2_default"
  scoreSource              String? // "REAL" | "PARTIAL" | "FALLBACK"
  // V7.5: dynamic scoring
  rawScore                 Float? // original fixed-weight score (= totalScore pre-v7.5)
  adaptiveScore            Float? // dynamic-weight score using stockStyle weights (0-100)
  stockStyle               String? // VALUE_DEFENSIVE | GROWTH_MOMENTUM | QUALITY_COMPOUNDER | SPECULATIVE_MOMENTUM | CYCLICAL_EXPORTER | DOMESTIC_DEFENSIVE
  highRiskFlag             Boolean   @default(false)
  fxSensitivity            String? // EXPORT_POSITIVE | DOMESTIC_NEUTRAL | IMPORT_SENSITIVE | FX_NEUTRAL
  catalystScore            Float? // 0-10, based on recent Disclosure events
  // V7.7: relative ranking + dual-threshold recommendation
  percentileRank           Float? // 1-100 (lower = better: 1=top 1%, 50=median, 100=bottom)
  marketRank               Int? // absolute rank by adaptiveScore (1=best in market)
  recommendationV2         String? // STRONG_BUY | BUY | HOLD | WATCH | AVOID (dual-threshold)
  recommendationReason     String? // human-readable reason for V2 rating
  // V7.7: opportunity scoring
  opportunityScore         Float? // 0-100 composite opportunity metric
  opportunityRank          Int? // rank by opportunityScore (1=best)
  opportunityLabel         String? // STEADY | HIGH_RISK_SPECULATIVE
  // V7.8: dividend & short selling
  dividendScore            Int? // 0-10 dividend quality score
  shortSellingSource       String? // "jpx_real" | "fallback"
  // V8.3 P2: AI Action trading decision layer
  tradingAction            String? // BUY_NOW | WAIT_PULLBACK | HOLD | TAKE_PROFIT | SELL | AVOID
  positionSizePct          Float? // recommended position size %
  entryLow                 Float? // entry price lower bound
  entryHigh                Float? // entry price upper bound
  stopLoss                 Float? // stop-loss price
  target1                  Float? // first target price
  target2                  Float? // second target price
  actionRiskLevel          String? // LOW | MEDIUM | HIGH | EXTREME
  actionReasons            Json? // string[]
  actionWarnings           Json? // string[]
  // V12.0: Decision Engine Safety Rules
  ruleConfidence           Float? // 0-100: how complete are the rule inputs
  newsConfidence           Float? // 0-100: news data quality/recency
  industryConfidence       Float? // 0-100: sector/industry data completeness
  modelConfidence          Float? // 0-100: TOHOSHOU model confidence (0 = disabled)
  overallConfidence        Float? // 0-100: weighted overall confidence
  riskOverride             String?   @default("NONE") // NONE | SOFT_BLOCK | HARD_BLOCK
  ruleEngineVersion        String? // e.g. "v1.0"
  globalEventEngineVersion String? // e.g. "v0.1"
  llmModelVersion          String? // e.g. "gpt-4o-mini"
  tohoshouModelVersion     String? // e.g. "disabled"
  scoringSchemaVersion     String? // e.g. "v1.0"
  shadowModelScore         Float? // TOHOSHOU shadow score (not used in production)
  shadowRecommendation     String? // TOHOSHOU shadow recommendation
  shadowRank               Int? // TOHOSHOU shadow rank
  shadowGeneratedAt        DateTime? // when shadow score was generated

  @@index([totalScore(sort: Desc)])
  @@index([adaptiveScore(sort: Desc)])
  @@index([recommendationV2])
  @@index([percentileRank])
  @@index([computedAt(sort: Desc)])
  @@index([market])
  @@index([recommendation])
}

// V7.8: Daily short selling ratio (JPX market-wide data)
model ShortSellingRatio {
  id                Int      @id @default(autoincrement())
  date              DateTime @db.Date
  market            String   @default("ALL") // ALL (TSE total) or market code
  shortSellRatio    Float? // short sell / total trading value (%)
  shortSellValue    Float? // short selling value (百万円)
  totalTradingValue Float? // total market trading value (百万円)
  source            String   @default("FALLBACK") // jpx_real | FALLBACK
  createdAt         DateTime @default(now())

  @@unique([date, market])
  @@index([date(sort: Desc)])
}

// Market-wide investor type weekly trading flow (TSE/JPX 投資部門別売買動向)
model InstitutionalFlow {
  id           Int      @id @default(autoincrement())
  date         DateTime @db.Date // week-ending Friday
  investorType String // foreigners | trust | corp | individual | dealer
  market       String   @default("ALL") // ALL | PRIME | STANDARD | GROWTH
  buyAmount    Float? // 買い（億円）
  sellAmount   Float? // 売り（億円）
  netAmount    Float? // 差引き = buy - sell（正=買越, 負=売越）
  source       String   @default("jpx") // jpx | synthetic
  createdAt    DateTime @default(now())

  @@unique([date, investorType, market])
  @@index([date(sort: Desc)])
}

// Global market snapshot (for globalTrendScore)
model GlobalMarket {
  id           Int      @id @default(autoincrement())
  date         DateTime @unique @db.Date
  // US market
  nasdaq       Float? // NASDAQ Composite close
  nasdaqChange Float? // 1-day % change
  sp500        Float? // S&P 500 close
  vix          Float? // VIX fear index level
  // Japan
  nikkei       Float? // Nikkei 225 close
  nikkeiChange Float? // 1-day % change
  topix        Float? // TOPIX close (or ETF proxy)
  topixChange  Float? // 1-day % change
  // FX
  usdjpy       Float? // USD/JPY spot
  // Legacy macro fields
  sox          Float?
  cpi          Float?
  fedRate      Float?
  // Computed score
  score        Int? // global trend score 0-10
  source       String   @default("yahoo") // yahoo | manual
  createdAt    DateTime @default(now())

  @@index([date(sort: Desc)])
}

// User watchlist – stocks to follow (separate from Portfolio which tracks actual positions)
model WatchList {
  id          Int      @id @default(autoincrement())
  symbol      String   @unique
  name        String
  sector      String?
  market      String?
  note        String?
  targetPrice Float?
  sortOrder   Int      @default(0)
  groupName   String?
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([addedAt(sort: Desc)])
  @@map("watch_list")
}

// V11: Realtime market snapshot — populated by /api/realtime-market on demand
model RealtimeMarket {
  symbol       String   @id
  price        Float?
  changePct    Float?
  volume       Float?
  volumeRatio  Float? // today's volume / avg10d volume
  turnoverRate Float? // volume / sharesOutstanding * 100
  marketCap    Float? // 億円
  rsi14        Float?
  ma5          Float?
  ma20         Float?
  ma60         Float?
  week52High   Float?
  week52Low    Float?
  updatedAt    DateTime @updatedAt

  @@map("realtime_market")
}

// Async background sync jobs (e.g. J-Quants full sync)
model SyncJob {
  id           String    @id @default(cuid())
  source       String
  status       String    @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILED
  total        Int       @default(0)
  processed    Int       @default(0)
  successCount Int       @default(0)
  failedCount  Int       @default(0)
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([source, createdAt(sort: Desc)])
  @@index([status])
}

// AI产业链主题分类 v8.0 (TOHOSHOU AI Supply Chain Map)
model AITheme {
  id               Int      @id @default(autoincrement())
  symbol           String
  theme            String // 14 fine-grained categories
  subTheme         String? // subdivision label
  role             String? // company role in supply chain
  supplyChainLayer String? // UPSTREAM | MIDSTREAM | DOWNSTREAM | INFRASTRUCTURE | APPLICATION
  importanceScore  Int      @default(5) // 1-10
  reason           String?  @db.Text
  riskNote         String?  @db.Text
  isCore           Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([symbol, theme])
  @@index([theme])
  @@index([symbol])
  @@index([supplyChainLayer])
  @@index([isCore])
  @@map("ai_themes")
}

// V9 P1: GPT Top500 Rerank — finalScore = gptScore (pure GPT, no weighting)
model GPTScore {
  symbol String @id
  model  String @default("gpt-4o-mini")

  ruleScore  Float
  gptScore   Float
  finalScore Float // = gptScore (V9 P1: pure GPT score, no weighting)

  // V9 P1 rerank fields
  gptRating String? // STRONG_BUY | BUY | HOLD | WATCH | AVOID (from finalScore+percentileRank)
  gptRank   Int? // rank within Top500 (1 = best, 500 = last in pool)

  // 7 GPT sub-dimension scores (0-100, null if not yet scored)
  businessQuality Int?
  growthScore     Int?
  industryScore   Int?
  moatScore       Int?
  valuationScore  Int?
  catalystScore   Int?
  riskScore       Int?

  confidence String // LOW | MEDIUM | HIGH
  action     String // POSITIVE | NEUTRAL | NEGATIVE

  summaryZh String @db.Text
  summaryJa String @db.Text
  summaryEn String @db.Text

  thesisZh String @db.Text
  thesisJa String @db.Text
  thesisEn String @db.Text

  strengths Json // string[]
  risks     Json // string[]
  catalysts Json // string[]

  timeHorizon String // 1-3M | 3-6M | 6-12M

  inputHash String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([finalScore(sort: Desc)])
  @@index([gptRank])
  @@index([updatedAt(sort: Desc)])
  @@map("gpt_scores")
}

// Daily Top500 snapshot for backtest (v10.0 Backtest MVP)
model DailyRecommendation {
  id                       Int       @id @default(autoincrement())
  date                     DateTime  @db.Date // JST date of recommendation
  symbol                   String
  gptRank                  Int // 1-500
  finalScore               Float
  adaptiveScore            Float
  gptScore                 Float
  gptRating                String?
  buyPrice                 Float? // StockScore.latestClose at rec time (reference only)
  recommendation           String? // StockScore.recommendationV2 at rec time (STRONG_BUY|BUY|HOLD|WATCH|AVOID)
  summaryZh                String?   @db.Text
  // v10.1: accurate entry/exit pricing
  entryDate                DateTime? @db.Date // first trading day after rec date
  entryPrice               Float? // raw open price on entryDate
  entryPriceType           String? // "NEXT_OPEN" | "NEXT_OPEN_FALLBACK"
  exitDate7d               DateTime? @db.Date // 7th trading day after entryDate
  exitDate30d              DateTime? @db.Date // 30th trading day after entryDate
  exitDate90d              DateTime? @db.Date // 90th trading day after entryDate
  priceSource              String? // "ADJUSTED" (adjClose) | "RAW" (close)
  price7d                  Float? // adjClose??close at exitDate7d
  price30d                 Float? // adjClose??close at exitDate30d
  price90d                 Float? // adjClose??close at exitDate90d
  return7d                 Float? // (price7d - entryPrice) / entryPrice * 100
  return30d                Float? // (price30d - entryPrice) / entryPrice * 100
  return90d                Float? // (price90d - entryPrice) / entryPrice * 100
  filledAt                 DateTime? // when price fills were last attempted
  createdAt                DateTime  @default(now())
  // V12.0: Decision Engine Safety Rules
  overallConfidence        Float? // snapshot of overallConfidence at rec time
  riskOverride             String? // snapshot of riskOverride at rec time
  ruleEngineVersion        String? // engine version used for this rec
  globalEventEngineVersion String?
  llmModelVersion          String?
  scoringSchemaVersion     String?
  // v13.3: Architecture v2.3 — version tracking
  // NOTE: return7d/return30d/return90d/exitDate*/price* below are DEPRECATED.
  // BacktestPositionResult is the source of truth for per-symbol backtest data.
  versionSnapshotId        String?
  modelVersion             String?
  scoreVersion             String?
  schemaVersion            String?
  pipelineRunId            String?
  // v13.4: Architecture v2.3 — feat_* immutable feature snapshot (Step 2)
  // Written ONCE at creation time. NEVER updated. Never backfilled. See ARCHITECTURE.md §6.
  feat_sector              String? // Stock.sector
  feat_industry            String? // Stock.industry (via StockScore)
  feat_marketCap           Float? // Stock.marketCap (億円)
  feat_per                 Float? // Stock.per
  feat_pbr                 Float? // Stock.pbr
  feat_roe                 Float? // Stock.roe (%)
  feat_dividendYield       Float? // Stock.dividend (%)
  feat_adaptiveScore       Float? // StockScore.adaptiveScore
  feat_technicalScore      Int? // StockScore.technicalScore (0-30)
  feat_fundamentalScore    Int? // StockScore.fundamentalScore (0-25)
  feat_moneyFlowScore      Int? // StockScore.moneyFlowScore (0-20)
  feat_newsSentimentScore  Int? // StockScore.newsSentimentScore (0-15)
  feat_globalTrendScore    Int? // StockScore.globalTrendScore (0-10)
  feat_percentileRank      Float? // StockScore.percentileRank (1-100)
  feat_marketRank          Int? // StockScore.marketRank (1=best)
  feat_stockStyle          String? // StockScore.stockStyle
  feat_highRiskFlag        Boolean? // StockScore.highRiskFlag
  feat_rsi14               Float? // StockScore.rsi14
  feat_maTrend             String? // StockScore.maTrend
  feat_ma20                Float? // 20-day MA of adjClose from DailyPrice
  feat_ma60                Float? // 60-day MA of adjClose from DailyPrice
  feat_return5d_pre        Float? // StockScore.return5d at rec time
  feat_return20d_pre       Float? // StockScore.return20d at rec time
  feat_return60d_pre       Float? // StockScore.return60d at rec time
  feat_volatility20d       Float? // Annualized vol % (last 20 DailyPrice log-returns)
  feat_vix                 Float? // GlobalMarket.vix at rec date
  feat_usdjpy              Float? // GlobalMarket.usdjpy at rec date
  feat_topixReturn5d       Float? // TOPIX 5-trading-day return %
  feat_topixReturn20d      Float? // TOPIX 20-trading-day return %
  feat_marketTemperature   Int? // GlobalMarket.score (0-10)

  // v15.0: Three-strategy classification (written at rec time, updated on each run)
  strategyType       String? // DAY | SWING | POSITION (null = legacy before v15.0)
  strategyConfidence Float? // 0-100
  targetReturnPct    Float? // 3.0 | 8.0 | 20.0
  stopLossPct        Float? // -2.0 | -4.0 | -8.0
  maxHoldingDays     Int? // 1 | 10 | 60

  @@unique([date, symbol])
  @@index([date(sort: Desc)])
  @@index([symbol])
  @@index([gptRank])
  @@index([strategyType])
  @@map("daily_recommendations")
}

// P6-T7: Daily AI Watchlist — 每日 AI 关注池
// 每个交易日把当天 DailyRecommendation 中 STRONG_BUY / BUY 的股票固化为一份独立
// 关注池（按 date+symbol 唯一，历史不覆盖）。纯派生/展示层：来源为现有
// DailyRecommendation / StockScore / DailyPrice，不参与也不影响任何评分/推荐逻辑。
// entryPrice/score/rank/name 在生成时快照冻结；currentPrice/changePct/returnPct
// 为最近一次刷新的快照（GET 时按现有数据源实时重算）；用户操作只改本行的
// status/isStarred/isMuted/isFocus/note，不删除历史记录。
model DailyAIWatchlist {
  id             Int      @id @default(autoincrement())
  date           DateTime @db.Date // JST 关注池日期
  symbol         String
  name           String? // Stock.nameZh ?? name 快照
  recommendation String // STRONG_BUY | BUY（生成时快照）
  rank           Int? // DailyRecommendation.gptRank 快照
  score          Float? // adaptiveScore 快照
  entryPrice     Float? // 推荐时价格（DailyRecommendation.buyPrice 快照，冻结）
  currentPrice   Float? // 最近刷新的现价快照
  changePct      Float? // 今日涨跌幅 %（EOD，最近刷新快照）
  returnPct      Float? // 推荐后涨跌 % =(current-entry)/entry（最近刷新快照）
  status         String   @default("ACTIVE") // ACTIVE | MUTED（取消关注）
  isStarred      Boolean  @default(false)
  isMuted        Boolean  @default(false)
  isFocus        Boolean  @default(false)
  note           String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([date, symbol])
  @@index([date(sort: Desc)])
  @@index([symbol])
  @@map("daily_ai_watchlist")
}

// Aggregated backtest results per cohort date + horizon (v10.0)
model BacktestResult {
  id                    Int      @id @default(autoincrement())
  date                  DateTime @db.Date
  horizon               String // "7d" | "30d" | "90d"
  totalRecommendations  Int
  filled                Int // stocks with valid price data
  winners               Int // return > 0
  losers                Int // return <= 0
  winRate               Float? // winners / filled * 100
  avgReturn             Float? // mean return of filled
  medianReturn          Float?
  bestReturn            Float?
  worstReturn           Float?
  bestSymbol            String?
  worstSymbol           String?
  computedAt            DateTime @default(now())
  // v10.1: portfolio size + benchmark
  portfolioSize         String   @default("ALL") // "ALL" | "TOP5" | "TOP10" | "TOP20"
  benchmarkNikkeiReturn Float?
  benchmarkTopixReturn  Float?
  excessVsNikkei        Float?
  excessVsTopix         Float?
  maxDrawdown           Float? // simplified: worstReturn within portfolio

  @@unique([date, horizon, portfolioSize])
  @@index([date(sort: Desc)])
  @@index([portfolioSize])
  @@map("backtest_results")
}

// Per-cohort error log when price data is missing (v10.1.1)
model BacktestError {
  id            Int      @id @default(autoincrement())
  symbol        String
  recommendDate DateTime @db.Date
  horizon       String? // "7d" | "30d" | "90d" | null (entry-level error)
  reason        String // "NO_DAILY_PRICE" | "NO_ENTRY_PRICE" | "NO_EXIT_PRICE"
  createdAt     DateTime @default(now())

  @@unique([symbol, recommendDate, horizon, reason])
  @@index([recommendDate(sort: Desc)])
  @@index([symbol])
  @@index([reason])
  @@map("backtest_errors")
}

// v13.3: Architecture v2.3 — version snapshot registry
model VersionSnapshot {
  id               String    @id // "YYYYMMDD-vX.Y", e.g., "20260626-v7.7"
  modelVersion     String // RULE_ENGINE_VERSION
  scoreVersion     String // SCORING_SCHEMA_VERSION
  schemaVersion    String // CURRENT_SCHEMA_VERSION (feat_* schema)
  ruleEngineVer    String
  scoringSchemaVer String
  llmModelVer      String
  startDate        DateTime  @db.Date
  endDate          DateTime? @db.Date // null = currently active
  isBaseline       Boolean   @default(false)
  changeLog        String?   @db.Text
  experimentId     String?
  createdAt        DateTime  @default(now())

  @@index([startDate(sort: Desc)])
  @@index([modelVersion])
  @@map("version_snapshots")
}

// v13.3: Architecture v2.3 — experiment registry
model ExperimentRegistry {
  id                String    @id
  versionSnapshotId String?
  startDate         DateTime  @db.Date
  endDate           DateTime? @db.Date
  hypothesis        String    @db.Text
  changes           String    @db.Text // JSON
  targetMetric      String
  targetThreshold   Float?
  status            String // PLANNED | RUNNING | COMPLETED | ABANDONED
  resultSummary     String?   @db.Text
  winRateDelta7d    Float?
  winRateDelta30d   Float?
  alphaDelta30d     Float?
  decision          String? // ADOPTED | REJECTED | PENDING
  decisionReason    String?   @db.Text
  decisionDate      DateTime? @db.Date
  nextExperimentId  String?
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())

  @@index([startDate(sort: Desc)])
  @@index([status])
  @@map("experiment_registries")
}

// v13.3: Architecture v2.3 — per-symbol per-horizon backtest source of truth
// DailyRecommendation.return7d/30d/90d/exitDate*/price* are DEPRECATED; read from here instead.
model BacktestPositionResult {
  id      Int      @id @default(autoincrement())
  recDate DateTime @db.Date // recommendation cohort date
  symbol  String
  horizon String // "1d"|"3d"|"5d"|"7d"|"10d"|"20d"|"30d"|"60d"|"90d"

  entryDate  DateTime? @db.Date
  entryPrice Float?
  exitDate   DateTime? @db.Date
  exitPrice  Float?
  returnPct  Float?
  winFlag    Boolean?

  benchmarkReturn Float? // TOPIX accumulated return for same period
  alphaVsTopix    Float? // returnPct - benchmarkReturn

  priceSource String? // "ADJUSTED" | "RAW"
  errorReason String? // "NO_ENTRY_PRICE" | "NO_EXIT_PRICE" | null

  modelVersion      String?
  scoreVersion      String?
  schemaVersion     String?
  versionSnapshotId String?
  pipelineRunId     String?

  computedAt DateTime @default(now())

  @@unique([recDate, symbol, horizon])
  @@index([recDate(sort: Desc)])
  @@index([symbol])
  @@index([horizon])
  @@index([modelVersion])
  @@index([versionSnapshotId])
  @@index([recDate, horizon])
  @@index([winFlag])
  @@map("backtest_position_results")
}

// v15.0: Strategy-based backtest results (DAY/SWING/POSITION simulation with stop-loss/take-profit)
model StrategyBacktestResult {
  id           Int      @id @default(autoincrement())
  recDate      DateTime @db.Date // recommendation cohort date
  symbol       String
  strategyType String // DAY | SWING | POSITION

  entryDate       DateTime? @db.Date
  entryPrice      Float?
  exitDate        DateTime? @db.Date
  exitPrice       Float?
  exitReason      String? // TAKE_PROFIT | STOP_LOSS | TIME_EXIT | OPEN | INSUFFICIENT_DATA
  holdingDays     Int?
  returnPct       Float?
  alphaPct        Float? // returnPct - benchmarkReturn
  isWin           Boolean?
  benchmarkReturn Float? // TOPIX accumulated return for same period

  computedAt DateTime @default(now())

  @@unique([recDate, symbol, strategyType])
  @@index([recDate(sort: Desc)])
  @@index([symbol])
  @@index([strategyType])
  @@index([exitReason])
  @@index([isWin])
  @@index([recDate, strategyType])
  @@map("strategy_backtest_results")
}

// Production Deployment History (v8.9.5)
model DeploymentLog {
  id              Int      @id @default(autoincrement())
  commitHash      String
  summary         String
  modifiedFiles   Json // string[]
  buildStatus     String   @default("SKIP") // PASS | FAIL | SKIP
  healthStatus    String   @default("SKIP") // PASS | WARNING | FAIL | SKIP
  apiStatus       String   @default("SKIP") // PASS | FAIL | SKIP
  pageStatus      String   @default("SKIP") // PASS | FAIL | SKIP
  databaseStatus  String   @default("SKIP") // PASS | FAIL | SKIP
  pm2Status       String   @default("SKIP") // PASS | FAIL | SKIP
  productionReady Boolean  @default(false)
  warnings        Json     @default("[]") // string[]
  blockingIssues  Json     @default("[]") // string[]
  operator        String   @default("Claude")
  deployedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([deployedAt(sort: Desc)])
  @@map("deployment_logs")
}

// V12.5: Daily AI Portfolio Snapshots — each day builds an independent ¥100M cohort
model PortfolioSnapshot {
  id                       Int       @id @default(autoincrement())
  snapshotDate             DateTime  @unique @db.Date
  name                     String
  initialCapital           Float     @default(100000000)
  cash                     Float // remaining cash after investment (fixed at creation)
  investedAmount           Float // sum(entryPrice × shares) — fixed
  positionCount            Int
  sourceRecommendationDate DateTime? @db.Date
  status                   String    @default("LIVE") // LIVE | COMPLETED | ARCHIVED
  completedAt              DateTime?
  benchmarkTopixEntry      Float? // TOPIX price at snapshot creation time
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  positions PortfolioSnapshotPosition[]

  @@index([snapshotDate(sort: Desc)])
  @@index([status])
  @@map("portfolio_snapshots")
}

model PortfolioSnapshotPosition {
  id                    Int               @id @default(autoincrement())
  snapshotId            Int
  snapshot              PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  symbol                String
  name                  String
  nameZh                String?
  entryPrice            Float // fixed at snapshot creation — never changes
  shares                Float // fixed, always multiple of 100
  entryAmount           Float // entryPrice × shares (fixed)
  gptRank               Int?
  aiScore               Float?
  action                String? // gptRating at snapshot time
  recommendation        String? // recommendationV2 at snapshot time
  // v17.1: 3:4:3 strategy allocation
  strategyType          String? // DAY | SWING | POSITION | null (null = legacy)
  allocationWeight      Float? // position's fraction of total portfolio (e.g. 0.10)
  strategyAllocationPct Float? // strategy bucket's target fraction (0.30/0.40/0.30)
  strategyConfidence    Float?
  targetReturnPct       Float?
  stopLossPct           Float?
  maxHoldingDays        Int?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([snapshotId])
  @@index([symbol])
  @@index([strategyType])
  @@map("portfolio_snapshot_positions")
}

// V12.7.0: Daily AI signal quality stats by recommendation type
model AISignalDailyStat {
  id                  Int      @id @default(autoincrement())
  tradeDate           DateTime @db.Date
  actionType          String // STRONG_BUY | BUY | ALL_BUY
  recommendationCount Int
  // Today stats
  validTodayCount     Int      @default(0)
  todayWinCount       Int      @default(0)
  todayLossCount      Int      @default(0)
  todayFlatCount      Int      @default(0)
  todayWinRate        Float?
  avgTodayReturnPct   Float?
  bestTodayReturnPct  Float?
  worstTodayReturnPct Float?
  // Today distribution buckets (today thresholds: ±3%)
  bigUpTodayCount     Int      @default(0) // ret >= +3%
  smallUpTodayCount   Int      @default(0) // 0 < ret < 3%
  smallDownTodayCount Int      @default(0) // -3% < ret < 0%
  bigDownTodayCount   Int      @default(0) // ret <= -3%
  // 7-day stats
  valid7dCount        Int      @default(0)
  win7dCount          Int      @default(0)
  loss7dCount         Int      @default(0)
  flat7dCount         Int      @default(0)
  win7dRate           Float?
  avg7dReturnPct      Float?
  best7dReturnPct     Float?
  worst7dReturnPct    Float?
  // 7-day distribution buckets (7d thresholds: ±5%)
  bigUp7dCount        Int      @default(0) // ret >= +5%
  smallUp7dCount      Int      @default(0) // 0 < ret < 5%
  smallDown7dCount    Int      @default(0) // -5% < ret < 0%
  bigDown7dCount      Int      @default(0) // ret <= -5%
  // Cohort: unique symbol dedup (per-day = same as regular; cross-day cohort future)
  uniqueSymbolCount   Int      @default(0)
  uniqueWinCount      Int      @default(0)
  uniqueWinRate       Float?
  calculatedAt        DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tradeDate, actionType])
  @@index([tradeDate(sort: Desc)])
  @@map("ai_signal_daily_stats")
}

// V12.6.2: User-controlled simulation trading account
model SimPortfolio {
  id          Int      @id @default(autoincrement())
  initialCash Float    @default(100000000)
  currentCash Float    @default(100000000)
  realizedPnl Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  positions SimPosition[]
  trades    SimTrade[]

  @@map("sim_portfolios")
}

model SimPosition {
  id          Int          @id @default(autoincrement())
  portfolioId Int
  portfolio   SimPortfolio @relation(fields: [portfolioId], references: [id])
  symbol      String
  name        String
  nameZh      String?
  avgCost     Float // weighted average cost per share
  shares      Int // must be multiple of 100
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([portfolioId, symbol])
  @@map("sim_positions")
}

model SimTrade {
  id          Int          @id @default(autoincrement())
  portfolioId Int
  portfolio   SimPortfolio @relation(fields: [portfolioId], references: [id])
  symbol      String
  name        String
  nameZh      String?
  action      String // BUY | SELL
  shares      Int
  price       Float // execution price
  amount      Float // price × shares
  realizedPnl Float? // set on SELL: (price - avgCost) × shares
  createdAt   DateTime     @default(now())

  @@index([portfolioId, createdAt(sort: Desc)])
  @@map("sim_trades")
}

// ═══════════════════════════════════════════════════════════
// Trading Architecture Phase 1 — Three-Strategy DB Foundation
// Added in v17.9.0 per docs/Trading-Architecture.md Phase 1
// ═══════════════════════════════════════════════════════════

enum StrategyType {
  DAY_TRADE
  SWING_TRADE
  LONG_TRADE
}

enum StrategyPositionStatus {
  OPEN
  CLOSED
}

enum StrategyTradeStatus {
  WAITING_OPEN
  WAITING_CLOSE
  CLOSED
  WAITING_DATA
  SKIPPED_MARKET_CLOSED
  SKIPPED_LOT_SIZE
  SKIPPED_DATA_MISSING
}

enum StrategyExitReason {
  DAY_CLOSE
  TAKE_PROFIT
  STOP_LOSS
  AI_SCORE_DROP
  DROPPED_FROM_TOP10
  MAX_HOLD_DAYS
  FUNDAMENTAL_RISK
  NEGATIVE_NEWS
  MANUAL
  MARKET_CLOSED
  DATA_MISSING
  LOT_SIZE_TOO_SMALL
}

// Each trading day's ranked candidates per strategy
model StrategyRecommendation {
  id           Int          @id @default(autoincrement())
  strategyType StrategyType
  tradeDate    DateTime     @db.Date
  symbol       String
  rank         Int

  aiScore          Float?
  technicalScore   Float?
  fundamentalScore Float?
  newsScore        Float?
  moneyFlowScore   Float?
  riskScore        Float?
  finalScore       Float?
  isTop10          Boolean @default(false)

  recommendationReason String?   @db.Text
  sourceScoreDate      DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([strategyType, tradeDate, symbol])
  @@index([strategyType, tradeDate, rank])
  @@index([strategyType, tradeDate, isTop10])
  @@index([tradeDate])
  @@index([symbol])
  @@map("strategy_recommendations")
}

// Swing/Long open and closed positions (Day Trade goes straight to StrategyTradeResult)
model StrategyPosition {
  id           Int          @id @default(autoincrement())
  strategyType StrategyType
  symbol       String

  entryDate  DateTime @db.Date
  entryPrice Float
  entryRank  Int?
  entryScore Float?

  currentDate  DateTime? @db.Date
  currentPrice Float?

  exitDate   DateTime?           @db.Date
  exitPrice  Float?
  exitReason StrategyExitReason?

  status         StrategyPositionStatus @default(OPEN)
  holdingDays    Int?
  quantity       Int                    @default(0)
  investedAmount Float?
  currentValue   Float?

  returnPct      Float?
  returnAmount   Float?
  topixReturnPct Float?
  alpha          Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([strategyType, symbol, entryDate])
  @@index([strategyType, status])
  @@index([symbol])
  @@index([entryDate])
  @@index([exitDate])
  @@map("strategy_positions")
}

// Completed trades — primary record for Day Trade, secondary for Swing/Long
model StrategyTradeResult {
  id           Int          @id @default(autoincrement())
  strategyType StrategyType
  tradeDate    DateTime     @db.Date
  symbol       String

  entryDate  DateTime? @db.Date
  entryPrice Float?
  exitDate   DateTime? @db.Date
  exitPrice  Float?

  quantity       Int    @default(0)
  investedAmount Float?
  exitValue      Float?

  returnPct      Float?
  returnAmount   Float?
  topixReturnPct Float?
  alpha          Float?
  win            Boolean?

  holdingDays Int?
  exitReason  StrategyExitReason?
  status      StrategyTradeStatus @default(WAITING_OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([strategyType, tradeDate, symbol])
  @@index([strategyType, tradeDate])
  @@index([symbol])
  @@map("strategy_trade_results")
}

// Daily performance snapshot per strategy — CREATE-only, immutable
model StrategySnapshot {
  id           Int          @id @default(autoincrement())
  strategyType StrategyType
  snapshotDate DateTime     @db.Date

  totalValue    Float?
  cash          Float?
  investedValue Float?

  dailyReturnPct      Float?
  cumulativeReturnPct Float?
  topixReturnPct      Float?
  alpha               Float?

  winRate       Float?
  openPositions Int?
  closedTrades  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([strategyType, snapshotDate])
  @@index([strategyType, snapshotDate])
  @@map("strategy_snapshots")
}

// Capital pool change log — each row records one capital event
model StrategyCapitalLog {
  id           Int          @id @default(autoincrement())
  strategyType StrategyType
  logDate      DateTime     @db.Date

  cashBefore     Float
  cashAfter      Float
  investedBefore Float
  investedAfter  Float
  totalBefore    Float
  totalAfter     Float

  changeAmount Float?
  changeReason String?

  createdAt DateTime @default(now())

  @@index([strategyType, logDate])
  @@map("strategy_capital_logs")
}

// Per-strategy per-horizon backtest aggregation
model StrategyBacktestSummary {
  id           Int          @id @default(autoincrement())
  strategyType StrategyType
  horizon      String
  asOfDate     DateTime     @db.Date

  sampleCount Int    @default(0)
  filledCount Int    @default(0)
  fillRate    Float?

  winRate         Float?
  lossRate        Float?
  avgReturnPct    Float?
  medianReturnPct Float?
  maxReturnPct    Float?
  minReturnPct    Float?
  avgHoldingDays  Float?
  maxHoldingDays  Int?
  topixReturnPct  Float?
  alpha           Float?
  maxDrawdown     Float?
  sharpeRatio     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([strategyType, horizon, asOfDate])
  @@index([strategyType, horizon])
  @@index([asOfDate])
  @@map("strategy_backtest_summaries")
}

// Per-strategy daily learning report (Phase 5)
model StrategyLearningReport {
  id           Int          @id @default(autoincrement())
  strategyType StrategyType
  reportDate   DateTime     @db.Date

  sampleCount  Int    @default(0)
  fillRate     Float?
  winRate      Float?
  avgReturnPct Float?
  alpha        Float?
  maxDrawdown  Float?

  predictionScore Float?
  stabilityScore  Float?
  confidenceScore Float?
  integrityScore  Float?

  grade          String? // A+, A, B, C, D
  recommendation String? // READY, PARTIAL, NOT_READY
  summary        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([strategyType, reportDate])
  @@index([strategyType])
  @@index([reportDate])
  @@map("strategy_learning_reports")
}

// Unified cross-strategy learning summary with weighted integrity score (Phase 5)
model StrategyLearningSummary {
  id         Int      @id @default(autoincrement())
  reportDate DateTime @unique @db.Date

  dayIntegrity   Float?
  swingIntegrity Float?
  longIntegrity  Float?
  integrityScore Float? // weighted: DAY×30% + SWING×40% + LONG×30%

  grade          String? // A+, A, B, C, D
  recommendation String? // READY, PARTIAL, NOT_READY
  summary        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("strategy_learning_summaries")
}

// Trading Architecture V1 — Daily validation record (T1 Stabilization)
model StrategyDailyValidation {
  id             Int      @id @default(autoincrement())
  validationDate DateTime @unique @db.Date

  // Check 1-3: Recommendations generated today
  dayRecOk   Boolean @default(false)
  swingRecOk Boolean @default(false)
  longRecOk  Boolean @default(false)

  // Check 4: Strategy scripts produced capital/position data
  strategyOk Boolean @default(false)

  // Check 5: Capital pool is being tracked
  snapshotOk Boolean @default(false)

  // Check 6: At least one trade result recorded
  tradeResultOk Boolean @default(false)

  // Check 7: Backtest updated today
  backtestOk Boolean @default(false)

  // Check 8: Learning updated today
  learningOk Boolean @default(false)

  // Check 9: All time-critical checks pass (derived health indicator)
  healthOk Boolean @default(false)

  // Overall
  allPass        Boolean @default(false)
  failCount      Int     @default(0)
  incidentReport String? @db.Text

  // Cumulative stats at time of validation
  dayFilledTotal   Int?
  swingClosedTotal Int?
  longClosedTotal  Int?
  dayWinRate       Float?
  swingWinRate     Float?
  longWinRate      Float?
  dayGrade         String?
  swingGrade       String?
  longGrade        String?

  // Phase 7 readiness snapshot
  phase7Ready  Boolean @default(false)
  phase7Detail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([validationDate])
  @@map("strategy_daily_validations")
}

// ─── T2 P5: Paper Broker (自动交易模拟账户) ──────────────────────────────────
// Isolated paper-trading layer. MIRRORS the three real strategy engines' executed
// trades (StrategyTradeResult for DAY, StrategyPosition for SWING/LONG) into a
// simulated ¥10M account (DAY 3M / SWING 4M / LONG 3M), sizing positions to its own
// pool. READ-ONLY vs. all strategy tables — never writes/modifies them. No real
// broker API. BROKER_MODE env (paper|live); only "paper" is implemented.

model PaperAccount {
  id             Int      @id @default(autoincrement())
  mode           String   @default("paper") // paper | live
  initialCapital Float    @default(10000000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("paper_accounts")
}

model PaperOrder {
  id           Int          @id @default(autoincrement())
  accountId    Int
  strategyType StrategyType
  symbol       String
  side         String // BUY | SELL
  orderDate    DateTime     @db.Date
  requestedQty Int
  filledQty    Int          @default(0)
  limitPrice   Float? // null = market
  status       String       @default("PENDING") // PENDING | FILLED | PARTIAL | CANCELLED | REJECTED
  rejectReason String? // LOT_SIZE_TOO_SMALL | INSUFFICIENT_CASH | ...
  sourceType   String // STRATEGY_TRADE_RESULT | STRATEGY_POSITION
  sourceId     Int // id of the mirrored source row (idempotency)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([accountId, strategyType, symbol, side, orderDate, sourceId])
  @@index([accountId, orderDate])
  @@index([strategyType, orderDate])
  @@map("paper_orders")
}

model PaperExecution {
  id           Int          @id @default(autoincrement())
  accountId    Int
  orderId      Int
  strategyType StrategyType
  symbol       String
  side         String // BUY | SELL
  execDate     DateTime     @db.Date
  price        Float
  quantity     Int
  amount       Float // price * quantity
  priceBasis   String // OPEN | CLOSE
  createdAt    DateTime     @default(now())

  @@index([accountId, execDate])
  @@index([orderId])
  @@map("paper_executions")
}

model PaperPosition {
  id             Int          @id @default(autoincrement())
  accountId      Int
  strategyType   StrategyType
  symbol         String
  status         String       @default("OPEN") // OPEN | CLOSED
  entryDate      DateTime     @db.Date
  entryPrice     Float
  quantity       Int
  investedAmount Float
  currentPrice   Float?
  currentValue   Float?
  exitDate       DateTime?    @db.Date
  exitPrice      Float?
  returnPct      Float?
  returnAmount   Float?
  sourceId       Int // mirrored StrategyTradeResult/StrategyPosition id
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([accountId, strategyType, status])
  @@index([symbol])
  @@map("paper_positions")
}

model PaperCashLog {
  id           Int          @id @default(autoincrement())
  accountId    Int
  strategyType StrategyType
  logDate      DateTime     @db.Date
  cashBefore   Float
  cashAfter    Float
  changeAmount Float
  reason       String
  orderId      Int?
  createdAt    DateTime     @default(now())

  @@index([accountId, strategyType, logDate])
  @@map("paper_cash_logs")
}

// ── Alpha Engine 2.0 — Phase 1 (P2-T1) ───────────────────────────────────────
// Strictly additive parallel data layer. NEVER consumed by StockScore / AdaptiveScore /
// GPT rank / DailyRecommendation / Portfolio in Phase 1 (data only).
model AlphaFactor {
  id                   Int      @id @default(autoincrement())
  symbol               String
  date                 DateTime @db.Date // latest trading day the factors are computed for
  // ① Relative Strength vs TOPIX (excess return %, N trading days)
  rs5                  Float?
  rs20                 Float?
  rs60                 Float?
  // ② ATR(14)
  atr14                Float?
  atrPct               Float?
  // ③ 52-week distance (signed %)
  distanceTo52WeekHigh Float?
  distanceTo52WeekLow  Float?
  // ④ liquidity
  averageTurnover20    Float?
  // ⑤ volume ratios
  volumeRatio5         Float?
  volumeRatio20        Float?
  // ⑥ consecutive expansion days
  volumeExpansionDays  Int?
  // event factors (Phase 1: interface, nullable)
  buyback              Boolean?
  dividendRaise        Boolean?
  guidanceRaise        Boolean?
  tdnetEvent           Boolean?
  computedAt           DateTime @default(now())

  @@unique([symbol, date])
  @@index([date])
  @@index([symbol])
  @@map("alpha_factors")
}

// ── Alpha Analytics — Phase 1.5 (P2-T1) ──────────────────────────────────────
// Per-factor historical effectiveness stats. Read-only analytics over DailyPrice-derived
// factor history + forward returns. NEVER consumed by production scoring/recommendation.
model AlphaFactorReport {
  id           Int       @id @default(autoincrement())
  period       Int // lookback window in days: 7 | 30 | 90 | 180
  factor       String // RelativeStrength | ATR | VolumeRatio | AverageTurnover | Distance52WeekHigh | VolumeExpansion
  sampleCount  Int       @default(0)
  meanFwdRet5  Float?
  meanFwdRet10 Float?
  meanFwdRet20 Float?
  winRate      Float? // % of fwd20 > 0
  meanExcess   Float? // mean(fwd20 − TOPIX fwd20)
  ic           Float? // Pearson(factor, fwd20)
  rankIc       Float? // Spearman(factor, fwd20)
  top20Ret     Float?
  bottom20Ret  Float?
  sharpe       Float?
  rating       Int       @default(1) // 1–5 stars
  ratingLabel  String    @default("Weak")
  asOfLatest   DateTime? @db.Date
  computedAt   DateTime  @default(now())

  @@unique([period, factor])
  @@index([period])
  @@map("alpha_factor_reports")
}

// ── Alpha Score — Phase 2A Shadow Mode (P2-T1) ───────────────────────────────
// Composite score from analytics-weighted Alpha factors. SHADOW ONLY — never fed into
// AdaptiveScore / GPT rank / DailyRecommendation / Portfolio.
model AlphaScore {
  id              Int      @id @default(autoincrement())
  symbol          String
  date            DateTime @db.Date
  alphaScore      Float // 0–100 (50 = universe average)
  composite       Float // raw weighted-z composite
  factorBreakdown Json // [{factor,value,z,direction,weight,contribution}]
  rank            Int // 1 = best
  percentile      Float // 0–100 (higher = better)
  computedAt      DateTime @default(now())

  @@unique([symbol, date])
  @@index([date, rank])
  @@map("alpha_scores")
}

// ── Alpha Shadow Backtest — Phase P2-T2 ──────────────────────────────────────
// Shadow validation: Production-score vs AlphaScore, reconstructed from DailyPrice.
// Read-only; never affects production scoring/recommendation.
model AlphaBacktestResult {
  id               Int       @id @default(autoincrement())
  period           Int // 30 | 90 | 180 (day window)
  strategy         String // PRODUCTION | ALPHA
  topN             Int // 10 | 20 | 50
  holdDays         Int // 5 | 10 | 20
  cumReturn        Float?
  alpha            Float? // annualized excess vs equal-weight market
  sharpe           Float?
  maxDrawdown      Float?
  winRate          Float?
  annualizedReturn Float?
  nObs             Int       @default(0)
  asOfLatest       DateTime? @db.Date
  computedAt       DateTime  @default(now())

  @@unique([period, strategy, topN, holdDays])
  @@index([period])
  @@map("alpha_backtest_results")
}

// ── Factor Alpha Result — P6-T9 Factor-level Alpha Engine ────────────────────
// Per-FEATURE, per-horizon TOPIX-excess alpha from a real forward-return backtest:
// reconstruct factor scalars from DailyPrice at N past as-of dates, rank the universe,
// take the top quintile cohort, measure its mean forward return at h∈{1,3,5,10,20}d and
// the same-date TOPIX forward return; alpha = cohort return − TOPIX return.
// READ-ONLY analytics — never read/written by production scoring / recommendation / portfolio.
model FactorAlphaResult {
  id          Int       @id @default(autoincrement())
  featureId   String // Feature Registry id (rs20 / atrPct / averageTurnover20 / …)
  horizon     Int // forward trading days: 1 | 3 | 5 | 10 | 20
  alpha       Float? // cohort avgReturn − TOPIX benchReturn (excess %)
  avgReturn   Float? // top-quintile cohort mean forward return %
  benchReturn Float? // TOPIX mean forward return over the cohort's as-of dates %
  hitRate     Float? // % of cohort obs with forward return > 0
  rankIc      Float? // Spearman(factor, forward return) — directional predictive power
  cohortSize  Int       @default(0) // avg top-quintile cohort size
  sampleCount Int       @default(0) // total (stock, as-of) observations
  asOfCount   Int       @default(0) // number of independent as-of (rebalance) dates
  asOfLatest  DateTime? @db.Date
  computedAt  DateTime  @default(now())

  @@unique([featureId, horizon])
  @@index([featureId])
  @@map("factor_alpha_results")
}

// ── Feature Platform Snapshot — P6-T10 Feature Platform Finalization ──────────
// 每日一行的 Feature Platform 状态快照：平台计数 + 晋升统计 + 平均 Alpha/贡献/置信
// + Integrity Score + Pending 分类 + TOPIX/benchmark 状态。供 Platform Report、
// Pending Trend、Integrity 历史。READ-ONLY 派生，不参与任何评分/推荐。
model FeaturePlatformSnapshot {
  id                    Int      @id @default(autoincrement())
  date                  DateTime @unique @db.Date // JST 日期
  production            Int      @default(0)
  shadow                Int      @default(0)
  disabled              Int      @default(0)
  pending               Int      @default(0)
  evaluated             Int      @default(0)
  promoteCandidates     Int      @default(0)
  keepShadow            Int      @default(0)
  disableCandidates     Int      @default(0)
  avgAlpha              Float? // 已评估影子因子 10d alpha 均值
  avgContribution       Float? // 平均贡献 %
  avgConfidence         Float? // 平均置信（HIGH100/MED65/LOW30）
  avgPromotionScore     Float?
  topFeature            String?
  topFeatureScore       Float?
  worstFeature          String?
  worstFeatureScore     Float?
  integrityScore        Float? // 0-100 链路完整性
  integrityIssues       Json? // [{code,severity,detail}]
  pendingByReason       Json? // {reasonCode: count}
  factorAlphaFresh      Boolean  @default(false) // FactorAlphaResult 今日已刷新
  factorAlphaComputedAt DateTime?
  benchmarkMode         String   @default("UNIVERSE") // UNIVERSE | TOPIX
  topixStatus           String? // BROKEN | RESTORED | FALLBACK
  createdAt             DateTime @default(now())

  @@map("feature_platform_snapshots")
}

// ── AI Top Picks — P7 Preview (Experimental V1) ──────────────────────────────
// 每日从 STRONG_BUY（不足 5 时补 top BUY）用「AI评分 + 因子Alpha + Contribution +
// Confidence + Risk」综合重排出 Top5。**独立实验模块 · 纯只读派生**：只读 StockScore /
// AlphaScore（已有数据），绝不修改 StrongBuy / DailyRecommendation / Promotion / Strategy /
// Watchlist / 任何评分逻辑。entryPrice 生成时冻结，历史不覆盖。
model AiTopPick {
  id             Int      @id @default(autoincrement())
  date           DateTime @db.Date // JST 生成日
  rank           Int // 1..5 by compositeScore
  symbol         String
  name           String?
  sourceRating   String // STRONG_BUY | BUY（SB 优先，不足 5 补 BUY）
  entryPrice     Float? // 生成时收盘价，冻结
  entryDate      DateTime @db.Date
  aiScore        Float? // StockScore.adaptiveScore
  alphaScore     Float? // AlphaScore.alphaScore（因子 alpha per stock）
  contribution   Float? // AlphaScore.percentile（因子排名强度）
  confidence     Float? // StockScore.ruleConfidence
  riskScore      Float? // 风险调整分（highRiskFlag 惩罚）
  compositeScore Float // 综合重排分 0-100（已扣动量惩罚）
  momentumPenalty Float  @default(0) // V1.1 Gate3：20日涨幅>阈值的惩罚分
  turnover       Float? // V1.1 Gate2：20日均成交额（日元）
  momentum20d    Float? // V1.1 Gate3：20日涨幅 %
  reason         String?
  currentPrice   Float? // 最近刷新快照（GET 实时重算）
  returnPct      Float? // 最近刷新快照
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([date, symbol])
  @@index([date, rank])
  @@map("ai_top_picks")
}

// ── AI Top Picks Filter Log — V1.1 Quality Gates（Experimental）──────────────
// 每日 Quality Gates 过滤统计 + 被拒候选，供页面 Filter Summary / Rejected Candidates。
// **只读派生 · 不影响任何生产推荐。**
model AiTopPickFilter {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique @db.Date
  candidates      Int      @default(0)
  newsReject      Int      @default(0)
  liquidityReject Int      @default(0)
  momentumPenalty Int      @default(0) // 被施加动量惩罚的只数
  finalPicks      Int      @default(0)
  rejected        Json? // [{symbol,name,sourceRating,reason,detail,turnover,momentum20d,compositeScore}]
  config          Json? // {liquidityMinYen,momentumThresholdPct,momentumPenalty,newsLookbackDays}
  createdAt       DateTime @default(now())

  @@map("ai_top_pick_filters")
}

// ── AI Top Picks Daily Performance — V1.1 Freeze Validation ──────────────────
// 每交易日 D 的已实现 1 日收益（日度再平衡模型）：cohort 用 DailyPrice close_D→close_{D+1}。
// 累计/胜率/回撤/Sharpe 由整段序列派生（API）。**只读派生，实验期算法固定，不影响任何生产。**
model AiTopPickPerf {
  id            Int      @id @default(autoincrement())
  date          DateTime @unique @db.Date // 建仓日 D（其 1 日前向收益已实现）
  fwdDate       DateTime @db.Date          // 实现日 D+1
  top5Ret       Float? // Top5 等权 1 日收益 %
  top5WinCount  Int      @default(0) // Top5 中 1 日正收益只数
  top5PickCount Int      @default(0)
  sbRet         Float? // STRONG_BUY cohort 平均 1 日收益 %
  sbCount       Int      @default(0)
  buyRet        Float? // BUY cohort 平均 1 日收益 %
  buyCount      Int      @default(0)
  topixRet      Float? // TOPIX 1 日收益 %
  createdAt     DateTime @default(now())

  @@map("ai_top_pick_perf")
}

// ── Market Regime — P2-T3 Adaptive Fusion Research ───────────────────────────
// Per-day Bull/Sideways/Bear classification (TOPIX MA stack + breadth + volatility).
// Research-only; never affects production scoring/recommendation.
model MarketRegime {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique @db.Date
  regime      String // BULL | SIDEWAYS | BEAR
  regimeScore Float?
  trendScore  Float?
  ma20        Float?
  ma60        Float?
  ma120       Float?
  topixClose  Float?
  breadth     Float? // % above MA20
  volatility  Float? // annualized %
  computedAt  DateTime @default(now())

  @@index([date])
  @@map("market_regimes")
}

// Per-regime Production vs Alpha stats + data-searched optimal fusion ratio.
model RegimeFusionResult {
  id               Int       @id @default(autoincrement())
  regime           String    @unique // BULL | SIDEWAYS | BEAR
  nDays            Int       @default(0)
  topN             Int       @default(20)
  holdDays         Int       @default(20)
  prodCumReturn    Float?
  prodSharpe       Float?
  prodWinRate      Float?
  prodMaxDrawdown  Float?
  alphaCumReturn   Float?
  alphaSharpe      Float?
  alphaWinRate     Float?
  alphaMaxDrawdown Float?
  bestAlphaWeight  Float? // 0..1 — fused = w·alpha + (1-w)·production
  fusedCumReturn   Float?
  fusedSharpe      Float?
  fusedWinRate     Float?
  fusedMaxDrawdown Float?
  objective        String    @default("SHARPE")
  gridJson         Json? // [{ w, sharpe, cumReturn }]
  asOfLatest       DateTime? @db.Date
  computedAt       DateTime  @default(now())

  @@map("regime_fusion_results")
}

// ── Fusion Paper Trading — P2-T4 ─────────────────────────────────────────────
// Forward paper trading: Production (real DailyRecommendation) vs AlphaScore vs Regime
// Fusion. Records daily Top10/Top20 picks + realized forward returns. READ-ONLY: the
// official recommendation / scoring / Portfolio are never modified.
model FusionPaperPick {
  id         Int      @id @default(autoincrement())
  entryDate  DateTime @db.Date
  strategy   String // PRODUCTION | ALPHA | FUSION
  topN       Int // 10 | 20
  symbol     String
  rank       Int
  entryClose Float?
  ret1d      Float?
  ret3d      Float?
  ret5d      Float?
  ret10d     Float?
  ret20d     Float?
  regime     String? // regime at entry (fusion context)
  computedAt DateTime @default(now())

  @@unique([entryDate, strategy, topN, symbol])
  @@index([entryDate, strategy])
  @@index([strategy, topN])
  @@map("fusion_paper_picks")
}

// ── Adaptive Score V3 Pro（P3-T1，Shadow-only 动态评分引擎）──────────────────
// 只写 Shadow 表；不改 StockScore / DailyRecommendation / Portfolio / GPT Rank。
model AdaptiveScoreV3Shadow {
  id                  Int      @id @default(autoincrement())
  symbol              String
  date                DateTime @db.Date
  scoreV3             Float // 0–100 加权动态复合分（已含风险扣分）
  rawScore            Float // 风险扣分前的加权分
  riskAdjustment      Float // -15..0
  rank                Int // 1 = best（本 date 内）
  percentile          Float // 0–100（higher = better）
  rating              String // STRONG_BUY | BUY | HOLD | WATCH | AVOID
  regime              String // 当日 MarketRegime（门控用，不加分）
  weightsJson         Json // 今日动态权重 { technical, fundamental, alpha, news, flow }
  factorBreakdownJson Json // 各维度 sub-score + 贡献
  riskAdjustmentJson  Json // 风险扣分明细
  explanation         String // 中文解释
  confidence          Float    @default(0) // 0–100 可信度
  qualityScore        Float    @default(0) // 0–100 数据质量
  calibrated          Boolean  @default(false)
  scoreVersion        String   @default("v3.0")
  computedAt          DateTime @default(now())

  @@unique([symbol, date])
  @@index([date, rank])
  @@index([date, scoreV3])
  @@map("adaptive_score_v3_shadow")
}

// ── V3 Calibration（P3-T3，每日动态阈值/分布/Confidence/Quality 报告）──────────
model AdaptiveScoreV3Calibration {
  id                  Int      @id @default(autoincrement())
  date                DateTime @unique @db.Date
  regime              String
  thresholdsJson      Json // 各评级 scoreV3 分数切点 + 目标分位
  ratingDistJson      Json // 校准后评级分布
  confidenceStatsJson Json // mean/median/p25/p75 + 分桶
  qualityJson         Json // 各维度覆盖率
  sectorJson          Json // STRONG_BUY 行业分布
  marketCapJson       Json // STRONG_BUY 市值分布
  sbStatsJson         Json // STRONG_BUY 统计
  readiness           Float    @default(0)
  readinessGrade      String   @default("D")
  computedAt          DateTime @default(now())

  @@map("adaptive_score_v3_calibration")
}

// ── Closing Decision — P6-T12 收盘决策（每交易日收盘前最终 AI 决策）───────────
// 每交易日 15:15 JST：全市场 EOD 排名（读 StockScore）+ 候选池实时行情覆盖（Yahoo）→
// GPT 分析 Top20 → 最终 Top10 + Decision Engine（BUY_TODAY/WATCH_ONLY/STAY_CASH）+
// Portfolio Builder（3-5 只建仓组合 + 仓位）。**独立模块 · 只读派生**：不修改
// StockScore / DailyRecommendation / DailyAIWatchlist / AiTopPick / 任何评分逻辑 / 其它 Cron。
// date 唯一，同日重跑幂等覆盖。additive 新表，无 breaking change。
model ClosingDecision {
  id           Int      @id @default(autoincrement())
  date         DateTime @unique @db.Date // JST 决策日
  computedAt   DateTime @default(now())
  decidedAtJst String? // 实际决策墙钟 HH:mm JST

  // ① 今日结论（每天恰好一个）
  verdict       String // BUY_TODAY | WATCH_ONLY | STAY_CASH
  verdictReason String? @db.Text

  // 市场上下文 / Decision Engine 输入快照
  regime         String? // BULL | SIDEWAYS | BEAR
  regimeScore    Float?
  marketTrend    Float? // trendScore
  volatility     Float? // 年化波动率 %
  avgAiScore     Float? // Top20 平均 AI 分
  avgRiskScore   Float? // Top20 平均风险分（0-100，越高越危险）
  buyZoneHitRate Float? // Top20 现价落在买区内占比 %
  breakoutRatio  Float? // Top20 已突破买区上沿占比 %
  newsRiskCount  Int     @default(0) // 高影响利空只数
  qualifiedCount Int     @default(0) // 可建仓合格候选数
  opportunity    Float? // Decision Engine 机会分（审计用）

  // ② 今日第一推荐（单独展示）
  top1Symbol     String?
  top1Name       String?
  top1AiScore    Float?
  top1GptScore   Float?
  top1Price      Float? // 实时
  top1ChangePct  Float?
  top1EntryLow   Float?
  top1EntryHigh  Float?
  top1Target1    Float?
  top1Target2    Float?
  top1StopLoss   Float?
  top1HoldPeriod String? // 建议持有时间，如 "1-3周（波段）"
  top1Confidence String? // A+ | A | B

  // ③ 今日建仓组合（3-5 只 or 空仓）
  portfolio     Json? // [{symbol,name,weight,price,entryLow,entryHigh,target1,stopLoss,aiScore,gptScore,sector,reason}]
  portfolioNote String? @db.Text // 组合说明 / "今日建议空仓"

  // ④ Top10（实时重排 + GPT overlay）
  top10 Json? // [{rank,symbol,name,price,changePct,aiScore,gptScore,rsi14,macdHist,ma5,ma10,ma20,volumeRatio,turnoverRate,newsSentiment,riskLevel,entryLow,entryHigh,target1,target2,stopLoss,action,inBuyZone,breakout,reason,gptNote}]

  // ⑥ 今日交易总结 + 推送文本（本期不真正外发）
  summary  String? @db.Text
  pushText String? @db.Text

  // 运行元数据
  gptModel       String?
  universeCount  Int     @default(0)
  shortlistCount Int     @default(0)
  gptAnalyzed    Int     @default(0)
  elapsedMs      Int     @default(0)

  @@map("closing_decisions")
}

// ═══════════════════════════════════════════════════════════
// P16-01 · User Portfolio（真实用户持仓 · 手工维护，非 PaperBroker/AI）
// 完整投资闭环：加入持有 → AI 每日管理 → 卖出(部分/全部) → History → 统计收益。
// additive：不影响 Decision Engine / Runtime Ranking / PaperBroker / 任何现有逻辑。
// ═══════════════════════════════════════════════════════════

// 单一用户账户（现金余额，供仓位/现金占比计算）
model UserAccount {
  id             Int      @id @default(autoincrement())
  cash           Float    @default(0) // 可用现金（用户可存取；买入减、卖出加）
  initialCapital Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_accounts")
}

// 当前持有（按 symbol 聚合的持仓；部分卖出减 shares，全部卖出删除）
model UserHolding {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  name      String
  shares    Float // 当前持有股数
  avgCost   Float // 加权平均成本
  openDate  DateTime @db.Date // 首次建仓日（用于持仓天数/基准对比）
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_holdings")
}

// 交易流水（买卖账本；SELL 行 = History）
model UserTrade {
  id            Int      @id @default(autoincrement())
  symbol        String
  name          String
  side          String // BUY | SELL
  shares        Float
  price         Float
  fee           Float    @default(0)
  tradeDate     DateTime @db.Date
  reason        String? // SELL: TAKE_PROFIT | STOP_LOSS | MANUAL | REBALANCE | OTHER
  note          String?
  // 平仓统计（仅 SELL）
  avgCostAtSell Float?
  realizedPnl   Float? // (price - avgCost) × shares - fee
  returnPct     Float?
  holdingDays   Int?
  benchTopixPct Float? // 同期 TOPIX 涨跌 %（跑赢判断）
  benchNikkeiPct Float? // 同期 Nikkei 涨跌 %
  createdAt     DateTime @default(now())

  @@index([symbol])
  @@index([side, tradeDate(sort: Desc)])
  @@map("user_trades")
}

// AI 决策/复盘时间线（P17-02 · 轻量附属表；不改任何核心交易表）。
// 一行 = 对某真实持仓的一次 AI 决策事件：成交触发(MANUAL_TRADE) 或 每日复盘(DAILY_REVIEW)。
// 用途：Decision Timeline（§7）/ Original·Latest Thesis（§6）/ Daily Review History（§9）/ Learning Record（§14）。
// AI 由此「知道自己过去说过什么」，不再每天从零分析。
model TradeDecisionHistory {
  id         Int       @id @default(autoincrement())
  symbol     String
  name       String
  action     String    // WATCH | BUY | HOLD | ADD | REDUCE | SELL | CLOSED
  source     String    // MANUAL_TRADE | DAILY_REVIEW
  price      Float?     // 当时价格
  returnPct  Float?     // 当时浮盈 %（相对成本）
  aiScore    Float?     // 当时 adaptiveScore
  reasonKey  String?    // i18n 依据键（复用 deriveHoldingActions / ai-verdict）
  reasonText String?    // 自由文本（用户备注 / 首因）
  rsi        Float?
  maTrend    String?
  outcome    String?    // 仅 SELL/CLOSED：HIT | MISS（AI 是否正确，供 Learning）
  holdingDays Int?      // 仅 SELL/CLOSED
  realizedPnl Float?    // 仅 SELL/CLOSED
  decidedAt  DateTime  @default(now())
  tradeDate  DateTime? @db.Date // 若由成交触发

  @@index([symbol, decidedAt(sort: Desc)])
  @@map("trade_decision_history")
}

// 组合每日净值快照（真账户 NAV 序列 · 轻量附属表；不改任何核心表）。
// 每交易日收盘写一条：equity = 持仓市值 + 现金；同日 TOPIX/Nikkei 收盘。
// 用途：AI Alpha 用真实 NAV 序列对比指数（7D/30D/90D 随历史积累变为实测，非当前持仓回看近似）。
model PortfolioNavSnapshot {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique @db.Date // JST 交易日，一天一条（upsert 幂等）
  equity      Float    // 总资产 = 持仓市值 + 现金
  marketValue Float    // 持仓市值
  cash        Float
  positions   Int      // 持仓数
  topix       Float?   // 当日 TOPIX 收盘
  nikkei      Float?   // 当日 Nikkei 收盘
  createdAt   DateTime @default(now())

  @@index([date(sort: Desc)])
  @@map("portfolio_nav_snapshots")
}
